# Everline API environment — copy to .env and fill in.

# HTTP port
PORT=3001

# Postgres connection string (local dev)
DATABASE_URL=postgresql://srglimasks@localhost:5432/everline

# JWT signing secret — generate a new one per environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me

# Frontend origin allowed by CORS. Must be exact (not *) because the API
# uses credentials: 'include' for cookie-based auth.
CORS_ORIGIN=http://localhost:8080

# Optional tunables
# PG_POOL_MAX=10
# PG_STATEMENT_TIMEOUT_MS=30000

# Set to "production" on the VPS so:
#   - cookies are marked Secure (HTTPS only)
#   - error responses stop leaking stack details
#   - morgan logs use the combined format
# NODE_ENV=production
