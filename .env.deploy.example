# Deploy credentials template — copy to .env.deploy.local and fill in.
# NEVER commit .env.deploy.local. It is gitignored via .env.*
#
# Usage before running deploy commands from DEPLOY.md:
#   set -a; . .env.deploy.local; set +a

# VPS (backend) — Hostinger VPS rodando Docker Swarm + Traefik
VPS_HOST=
VPS_SSH_PASS=

# Postgres na VPS (porta 5432, user postgres, db postgres)
PG_PASS=

# JWT signing secret (produção). Gerar com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Origem permitida pelo CORS (frontend em produção)
CORS_ORIGIN=https://agenciaeverline.com.br

# DATABASE_URL do container — host.docker.internal resolve pro host via extra_hosts
DATABASE_URL=postgresql://postgres:${PG_PASS}@host.docker.internal:5432/postgres

# Hostinger (frontend) — shared hosting SSH/FTP
HOSTINGER_HOST=
HOSTINGER_SSH_PASS=

# Admin seed (só usado por `npm run seed`)
SEED_ADMIN_EMAIL=sergiolima@agenciaevergrowth.com.br
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Sergio Lima
